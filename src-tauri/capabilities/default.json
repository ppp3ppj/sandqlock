{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "opener:default",
    "store:default",
    "websocket:default",
    {
      "identifier": "http:default",
      "allow": [
        {
          "url": "http://localhost:4000/*"
        },
        {
          "url": "ws://localhost:4000/*"
        }
      ],
      "deny": []
    }
  ]
}
